# Configurazione Database (Valori predefiniti per l'ambiente di sviluppo locale)
DB_CONNECTION_URI="sqlite:./wikiblank.sqlite"
DIALECT="sqlite"

# Sicurezza JWT (Sostituisci questo valore nel tuo .env con una stringa lunga, sicura e casuale)
TOKEN_SECRET="inserisci_qui_la_tua_chiave_segreta"

# Configurazione Server
PORT=3000